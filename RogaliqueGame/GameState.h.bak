#pragma once
#include <iostream>
#include <memory>
#include <vector>
#include <SFML/Graphics.hpp>

namespace RogaliqueGame
{
    // Типы состояний
    enum class GameStateType
    {
        None,
        MainMenu,
        Playing,
        Paused,
        GameOver,
        Win
    };

    // Базовый класс состояния
    class GameState
    {
    public:
        virtual ~GameState() = default;
        virtual void Update(float deltaTime) = 0;
        virtual void Draw(sf::RenderWindow& window) = 0;
        virtual void HandleInput() = 0;

        GameStateType GetType() const { return m_type; }

    protected:
        GameStateType m_type = GameStateType::None;
    };

    // Состояние: Игра
    class GameStatePlaying : public GameState
    {
    public:
        GameStatePlaying();
        void Update(float deltaTime) override;
        void Draw(sf::RenderWindow& window) override;
        void HandleInput() override;
    };

    // Состояние: Пауза
    class GameStatePaused : public GameState
    {
    public:
        GameStatePaused();
        void Update(float deltaTime) override;
        void Draw(sf::RenderWindow& window) override;
        void HandleInput() override;
    };

    // Состояние: Главное меню
    class GameStateMainMenu : public GameState
    {
    public:
        GameStateMainMenu();
        void Update(float deltaTime) override;
        void Draw(sf::RenderWindow& window) override;
        void HandleInput() override;
    };

    // Состояние: Проигрыш
    class GameStateGameOver : public GameState
    {
    public:
        GameStateGameOver(int score = 0);
        void Update(float deltaTime) override;
        void Draw(sf::RenderWindow& window) override;
        void HandleInput() override;

    private:
        int m_score;
    };

    // Состояние: Победа
    class GameStateWin : public GameState
    {
    public:
        GameStateWin(int score = 0);
        void Update(float deltaTime) override;
        void Draw(sf::RenderWindow& window) override;
        void HandleInput() override;

    private:
        int m_score;
    };
}